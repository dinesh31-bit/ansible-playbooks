pipeline{
    agent {label 'ansible'}
    environment {
        ansible_server = "13.201.37.48"  // ← Add this
    }
    stages{
        stage("git clone"){
            steps{
                git branch: 'main', credentialsId: 'dinesh31bitgit', url: 'https://github.com/dinesh31-bit/ansible-playbooks.git'
            }
        }
        stage("ping the servers"){
            steps{
                withCredentials([file(credentialsId: 'ansible_node_file', variable: 'ansible_node')]) {
                    sh "ansible tomcat_servers -i ansible_sccripts/hosts -m ping -e ansible_ssh_private_key_file=${ansible_node} --ssh-common-args='-o StrictHostKeyChecking=no"
                }
            }
        }
        stage("install Tomcat"){
            steps{
                withCredentials([file(credentialsId: 'ansible_node_file', variable: 'ansible_node')]) {
                    sh "ansible-playbook -i ansible_sccripts/hosts ansible_sccripts/tomcat_install.yaml -e ansible_ssh_private_key_file=${ansible_node} --ssh-common-args='-o StrictHostKeyChecking=no"
            }
        }

    }
}